# ── Required ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/seahawk

# JWT — use long random strings in production
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-also-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# ── Optional: Email (SMTP) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Sea Hawk Courier <noreply@seahawkcourier.com>

# ── Internal Assistants ───────────────────────────────────────────────────
# Ops and client assistants work from your own portal logic and data.
# No paid AI key is required for core assistant features.

# ── OCR Engine (free local mode by default) ───────────────────────────────
# local = python + RapidOCR + zxing-cpp (recommended)
# auto  = local first, Gemini fallback if configured
# gemini= Gemini Vision only
OCR_ENGINE=local
OCR_PYTHON_BIN=python
OCR_LOCAL_TIMEOUT_MS=60000
# Install local OCR deps:
#   cd backend && npm run ocr:local:setup

# ── Scanner quality targets (explicit optimization goals) ───────────────────
SCANNER_SLA_BARCODE_FIRST_PASS_PCT=92
SCANNER_SLA_AWB_EXTRACTION_PCT=97
SCANNER_SLA_OCR_FALLBACK_MAX_PCT=15
SCANNER_SLA_FALSE_LOCK_MAX_PCT=1
SCANNER_SLA_LOCK_P95_MS=800
SCANNER_SLA_FAST_P95_MS=1200
SCANNER_SLA_OCR_P95_MS=20000
SCANNER_OCR_BUDGET_MS=22000

# Scanner benchmark dataset storage metadata (optional)
SCANNER_DATASET_BUCKET=
SCANNER_DATASET_PREFIX=scanner-gold

# ── Optional: Google Gemini (used only when OCR_ENGINE=gemini/auto) ───────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Optional: WhatsApp (Meta Cloud API) ───────────────────────────────────
WHATSAPP_TOKEN=your-meta-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id

# ─── Redis / Job Queue ────────────────────────────
# Without Redis: background jobs run inline (fine for low volume).
# With Redis: proper async queue with retries (Critical for Production).
# Railway Instructions: 
# 1. Add Redis service to your project.
# 2. Railway automatically sets REDIS_URL for your backend.
# 3. For local use, copy the "External Redis URL" from Railway Variables.
REDIS_URL=

# ── Optional: Carrier APIs ────────────────────────────────────────────────
DELHIVERY_API_KEY=
DELHIVERY_API_URL=https://track.delhivery.com
REVERSE_HUB_NAME=Sea Hawk Courier & Cargo
REVERSE_HUB_ADDRESS=Shop 6 & 7, Rao Lal Singh Market, Sector-18
REVERSE_HUB_CITY=Gurugram
REVERSE_HUB_STATE=Haryana
REVERSE_HUB_PIN=122015
REVERSE_HUB_PHONE=9999999999
DTDC_API_KEY=
DTDC_ACCESS_TOKEN=
DTDC_USERNAME=
DTDC_PASSWORD=
DTDC_CUSTOMER_CODE=
DTDC_AUTH_API_URL=https://blktracksvc.dtdc.com/dtdc-api/api/dtdc/authenticate
DTDC_TRACKING_API_URL=https://blktracksvc.dtdc.com/dtdc-tracking-api/dtdc-api/rest/JSONCnTrk/getTrackDetails
TRACKON_APP_KEY=
TRACKON_USER_ID=
TRACKON_PASSWORD=
TRACKON_TRACKING_API_URL=https://api.trackon.in
TRACKON_BOOKING_API_URL=http://trackon.in:5455
TRACKON_CUSTOMER_CODE=
TRACKON_PICKUP_CUST_CODE=
TRACKON_PICKUP_CUST_NAME=
TRACKON_PICKUP_ADDR=
TRACKON_PICKUP_CITY=
TRACKON_PICKUP_STATE=
TRACKON_PICKUP_PINCODE=
TRACKON_PICKUP_PHONE=
BLUEDART_LICENSE_KEY=
BLUEDART_LOGIN_ID=

# ── Optional: Razorpay ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Optional: DB Backups (S3 or Cloudflare R2) ────────────────────────────
BACKUP_S3_BUCKET=seahawk-backups
BACKUP_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Optional: Sentry ──────────────────────────────────────────────────────
SENTRY_DSN=

# ── Optional: Live Excel/Sheet Integration ────────────────────────────────
INTEGRATION_SYNC_API_KEY=
