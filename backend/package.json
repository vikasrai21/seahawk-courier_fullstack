{
  "name": "seahawk-backend",
  "version": "8.0.0",
  "description": "Seahawk Courier & Cargo — Production Backend",
  "main": "server.js",
  "scripts": {
    "start": "npx prisma migrate resolve --rolled-back \"20260319143343_phase3_client_portal\" && npx prisma migrate deploy && node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "build": "npx prisma generate",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "node src/utils/seed.js",
    "auth:bootstrap-owner": "node src/utils/bootstrap-owner.js",
    "auth:bootstrap-demo": "node src/utils/bootstrap-users.js --restore-demo",
    "auth:reset-admin": "node src/utils/bootstrap-users.js --reset-admin",
    "lint": "eslint src --ext .js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.10.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "pdfkit": "^0.14.0",
    "razorpay": "^2.9.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "yaml": "^2.8.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "typescript": "^6.0.2",
    "vitest": "^1.3.1"
  }
}
