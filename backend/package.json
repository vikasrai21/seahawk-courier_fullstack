{
  "name": "seahawk-backend",
  "version": "8.0.0",
  "description": "Seahawk Courier & Cargo — Production Backend",
  "main": "server.js",
  "scripts": {
    "start":            "node server.js",
    "dev":              "cross-env NODE_ENV=development nodemon server.js",
    "build":            "npx prisma generate",
    "test":             "vitest run",
    "test:watch":       "vitest",
    "test:coverage":    "vitest run --coverage",
    "prisma:generate":  "prisma generate",
    "prisma:migrate":   "prisma migrate deploy",
    "prisma:studio":    "prisma studio",
    "db:seed":          "node src/utils/seed.js",
    "lint":             "eslint src --ext .js",
    "tokens:cleanup":   "node -e \"require('./src/services/auth.service').cleanupExpiredTokens().then(() => process.exit(0))\""
  },
  "dependencies": {
    "@prisma/client":   "^5.10.0",
    "bcryptjs":         "^2.4.3",
    "cookie-parser":    "^1.4.6",
    "cors":             "^2.8.5",
    "dotenv":           "^16.4.1",
    "express":          "^4.18.3",
    "express-rate-limit":"^7.2.0",
    "helmet":           "^7.1.0",
    "jsonwebtoken":     "^9.0.2",
    "morgan":           "^1.10.0",
    "node-cron":        "^3.0.3",
    "winston":          "^3.11.0",
    "zod":              "^3.22.4",
    "pdfkit":           "^0.14.0",
    "razorpay":         "^2.9.2",
    "bullmq":           "^5.4.0",
    "ioredis":          "^5.3.2",
    "nodemailer":       "^6.9.9",
    "axios":            "^1.6.7",
    "cross-env":        "^7.0.3",
    "crypto":           "^1.0.1"
  },
  "devDependencies": {
    "nodemon":   "^3.1.0",
    "prisma":    "^5.10.0",
    "vitest":    "^1.3.1",
    "supertest": "^6.3.4",
    "eslint":    "^8.57.0"
  }
}
