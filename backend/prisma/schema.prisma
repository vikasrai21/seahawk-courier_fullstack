generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  OPS_MANAGER
  STAFF
  CLIENT
}

model User {
  id                      Int                 @id @default(autoincrement())
  name                    String
  email                   String              @unique
  password                String
  role                    UserRole            @default(STAFF)
  branch                  String?
  phone                   String?
  active                  Boolean             @default(true)
  loginAttempts           Int                 @default(0) @map("login_attempts")
  lockedUntil             DateTime?           @map("locked_until")
  mustChangePassword      Boolean             @default(false) @map("must_change_password")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")
  shipmentsCreated        Shipment[]          @relation("CreatedBy")
  shipmentsUpdated        Shipment[]          @relation("UpdatedBy")
  auditLogs               AuditLog[]
  quotesCreated           Quote[]             @relation("QuoteCreatedBy")
  courierInvoicesUploaded CourierInvoice[]    @relation("InvoiceUploadedBy")
  rateVersionsUploaded    RateVersion[]       @relation("RateVersionUploadedBy")
  pickupAssignments       PickupRequest[]     @relation("AssignedAgent")
  refreshTokens           RefreshToken[]
  clientProfile           ClientUser?
  importedRows            ShipmentImportRow[] @relation("ImportRowCreatedBy")

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int       @map("user_id")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  ip        String?
  userAgent String?   @map("user_agent")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model ClientUser {
  id         Int    @id @default(autoincrement())
  userId     Int    @unique @map("user_id")
  clientCode String @map("client_code") @db.VarChar(20)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client     Client @relation(fields: [clientCode], references: [code])

  @@map("client_users")
}

model Client {
  id            Int                 @id @default(autoincrement())
  code          String              @unique @db.VarChar(20)
  company       String
  normalizedName String?            @map("normalized_name")
  contact       String?
  phone         String?
  whatsapp      String?
  email         String?
  gst           String?
  address       String?
  notes         String?
  active        Boolean             @default(true)
  walletBalance Decimal             @default(0) @map("wallet_balance") @db.Decimal(12,2)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  shipments     Shipment[]
  contracts     Contract[]
  invoices      Invoice[]
  quotes        Quote[]
  pickups       PickupRequest[]
  transactions  WalletTransaction[]
  clientUsers   ClientUser[]
  importedRows  ShipmentImportRow[]
  DraftOrder      DraftOrder[]
  returnRequests  ReturnRequest[]
  autoTopupRule   Json?               @map("auto_topup_rule")
  brandSettings   Json?               @map("brand_settings")
  notificationConfig Json?             @map("notification_config")
  apiKeys         ClientApiKey[]
  webhooks        ClientWebhook[]
  warehouses      Warehouse[]
  codRemittances  CODRemittance[]
  customerFeedback CustomerFeedback[]
  channelIntegrations ChannelIntegration[]
  onboardingApplications OnboardingApplication[]
  weightDisputes  WeightDispute[]

  @@index([code])
  @@index([normalizedName])
  @@map("clients")
}

model ClientApiKey {
  id          Int       @id @default(autoincrement())
  clientCode  String    @map("client_code") @db.VarChar(20)
  name        String
  tokenHash   String    @unique @map("token_hash")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  client      Client    @relation(fields: [clientCode], references: [code], onDelete: Cascade)

  @@index([clientCode])
  @@index([tokenHash])
  @@map("client_api_keys")
}

model Contract {
  id            Int      @id @default(autoincrement())
  clientCode    String   @map("client_code") @db.VarChar(20)
  name          String
  courier       String?
  service       String?
  pricingType   String   @default("PER_KG") @map("pricing_type")
  baseRate      Decimal  @default(0) @map("base_rate") @db.Decimal(12,2)
  baseCharge    Decimal  @default(0) @map("base_charge") @db.Decimal(12,2)
  minCharge     Decimal  @default(0) @map("min_charge") @db.Decimal(12,2)
  fuelSurcharge Decimal  @default(0) @map("fuel_surcharge") @db.Decimal(12,2)
  gstPercent    Decimal  @default(18) @db.Decimal(12,4) @map("gst_percent")
  pricingRules  Json?    @map("pricing_rules")
  validFrom     String?  @map("valid_from")
  validTo       String?  @map("valid_to")
  active        Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  client        Client   @relation(fields: [clientCode], references: [code])

  @@index([clientCode])
  @@index([active])
  @@map("contracts")
}

model Shipment {
  id             Int                 @id @default(autoincrement())
  date           String              @db.VarChar(10)
  clientCode     String              @map("client_code") @db.VarChar(20)
  awb            String              @unique @db.VarChar(50)
  consignee      String?
  destination    String?
  phone          String?
  pincode        String?
  weight        Decimal  @default(0) @db.Decimal(12,4)
  amount         Decimal             @default(0) @db.Decimal(12,2)
  cost           Decimal?            @default(0) @db.Decimal(12,2)
  profit         Decimal?            @default(0) @db.Decimal(12,2)
  courier        String?
  department     String?
  service        String              @default("Standard")
  status         String              @default("Booked")
  ndrStatus      String?             @map("ndr_status")
  remarks        String?
  labelUrl       String?             @map("label_url")
  environment    String              @default("production") @db.VarChar(20)
  sandboxRunId   String?             @map("sandbox_run_id") @db.VarChar(50)
  sourcePlatform String?             @map("source_platform") @db.VarChar(30)
  simulationState Json?              @map("simulation_state")
  riskScore      Float?              @map("risk_score")
  riskFactors    Json?               @map("risk_factors")
  marginAlert    Boolean             @default(false) @map("margin_alert")
  // ── Feature Gap Fields ──────────────────────────────────────────────
  codAmount      Decimal             @default(0) @map("cod_amount") @db.Decimal(12,2)
  codStatus      String?             @map("cod_status") @db.VarChar(30) // PENDING, COLLECTED, REMITTED
  codRemittanceId Int?               @map("cod_remittance_id")
  predictedDeliveryDate String?      @map("predicted_delivery_date") @db.VarChar(10)
  warehouseId    Int?                @map("warehouse_id")
  channelSource  String?             @map("channel_source") @db.VarChar(30) // SHOPIFY, WOOCOMMERCE, MANUAL
  channelOrderId String?             @map("channel_order_id") @db.VarChar(100)
  labelFormat    String?             @map("label_format") @db.VarChar(10) // 4x6, A4
  labelGeneratedAt DateTime?         @map("label_generated_at")
  createdById    Int?                @map("created_by_id")
  updatedById    Int?                @map("updated_by_id")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  client         Client              @relation(fields: [clientCode], references: [code])
  createdBy      User?               @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy      User?               @relation("UpdatedBy", fields: [updatedById], references: [id])
  invoiceItems   InvoiceItem[]
  trackingEvents TrackingEvent[]
  ndrEvents      NDREvent[]
  importRows      ShipmentImportRow[]
  DraftOrder      DraftOrder?
  returnRequests  ReturnRequest[]
  warehouse      Warehouse?          @relation(fields: [warehouseId], references: [id])
  codRemittance  CODRemittance?      @relation(fields: [codRemittanceId], references: [id])
  weightDisputes WeightDispute[]
  customerFeedback CustomerFeedback[]

  @@index([date])
  @@index([clientCode])
  @@index([status])
  @@index([courier])
  @@index([environment])
  @@index([sandboxRunId])
  @@index([sourcePlatform])
  @@index([ndrStatus])
  @@index([date, clientCode])
  @@index([courier, status])
  @@index([date, status])
  @@index([clientCode, date])
  @@index([date, status, environment])
  @@index([codStatus])
  @@index([channelSource])
  @@index([warehouseId])
  @@map("shipments")
}

model ShipmentImportRow {
  id          Int       @id @default(autoincrement())
  batchKey    String    @map("batch_key")
  sourceFile  String?   @map("source_file")
  sourceSheet String?   @map("source_sheet")
  rowNo       Int?      @map("row_no")
  date        String    @db.VarChar(10)
  clientCode  String    @map("client_code") @db.VarChar(20)
  awb         String    @db.VarChar(50)
  consignee   String?
  destination String?
  phone       String?
  pincode     String?
  weight        Decimal  @default(0) @db.Decimal(12,4)
  amount      Decimal   @default(0) @db.Decimal(12,2)
  courier     String?
  department  String?
  service     String    @default("Standard")
  status      String    @default("Booked")
  ndrStatus   String?   @map("ndr_status")
  remarks     String?
  autoPriced  Boolean   @default(false) @map("auto_priced")
  shipmentId  Int?      @map("shipment_id")
  createdById Int?      @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  client      Client    @relation(fields: [clientCode], references: [code])
  shipment    Shipment? @relation(fields: [shipmentId], references: [id])
  createdBy   User?     @relation("ImportRowCreatedBy", fields: [createdById], references: [id])

  @@index([batchKey])
  @@index([date])
  @@index([clientCode])
  @@index([awb])
  @@index([courier])
  @@index([status])
  @@map("shipment_import_rows")
}

model TrackingEvent {
  id          Int      @id @default(autoincrement())
  shipmentId  Int      @map("shipment_id")
  awb         String   @db.VarChar(50)
  status      String
  location    String?  @default("")
  description String?  @default("")
  timestamp   DateTime @default(now())
  source      String   @default("MANUAL")
  rawData     Json?    @map("raw_data")
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([awb])
  @@index([timestamp])
  @@map("tracking_events")
}

model SandboxRun {
  id                Int      @id @default(autoincrement())
  runId             String   @unique @map("run_id") @db.VarChar(50)
  clientCode        String?  @map("client_code") @db.VarChar(20)
  platformType      String?  @map("platform_type") @db.VarChar(30)
  totalOrders       Int      @default(0) @map("total_orders")
  totalShipments    Int      @default(0) @map("total_shipments")
  failedOrders      Int      @default(0) @map("failed_orders")
  status            String   @default("success") @db.VarChar(20)
  orders            Json     @default("[]")
  shipments         Json     @default("[]")
  errors            Json     @default("[]")
  statusProgression Json     @default("[]") @map("status_progression")
  logs              Json     @default("[]")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([clientCode])
  @@index([platformType])
  @@index([status])
  @@index([createdAt])
  @@map("sandbox_runs")
}

model NDREvent {
  id          Int       @id @default(autoincrement())
  shipmentId  Int       @map("shipment_id")
  awb         String    @db.VarChar(50)
  reason      String
  description String?   @default("")
  attemptNo   Int       @default(1) @map("attempt_no")
  action      String    @default("PENDING")
  newAddress  String?   @map("new_address")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([awb])
  @@index([action])
  @@map("ndr_events")
}

model PickupRequest {
  id               Int       @id @default(autoincrement())
  requestNo        String    @unique @map("request_no") @db.VarChar(30)
  clientCode       String?   @map("client_code") @db.VarChar(20)
  contactName      String    @map("contact_name")
  contactPhone     String    @map("contact_phone")
  contactEmail     String?   @map("contact_email")
  pickupAddress    String    @map("pickup_address")
  pickupCity       String    @map("pickup_city")
  pickupPin        String    @map("pickup_pin")
  deliveryAddress  String?   @map("delivery_address")
  deliveryCity     String?   @map("delivery_city")
  deliveryState    String?   @map("delivery_state")
  deliveryCountry  String    @default("India") @map("delivery_country")
  packageType      String    @default("Parcel") @map("package_type")
  weightGrams      Decimal   @default(0) @map("weight_grams") @db.Decimal(12,2)
  pieces           Int       @default(1)
  service          String    @default("Standard")
  declaredValue    Decimal?  @map("declared_value") @db.Decimal(12,2)
  notes            String?
  source           String    @default("PORTAL")
  preferredCarrier String?   @map("preferred_carrier")
  scheduledDate    String    @map("scheduled_date")
  timeSlot         String    @map("time_slot")
  assignedAgentId  Int?      @map("assigned_agent_id")
  assignedAt       DateTime? @map("assigned_at")
  completedAt      DateTime? @map("completed_at")
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  client           Client?   @relation(fields: [clientCode], references: [code])
  assignedAgent    User?     @relation("AssignedAgent", fields: [assignedAgentId], references: [id])

  @@index([status])
  @@index([scheduledDate])
  @@index([clientCode])
  @@map("pickup_requests")
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  clientCode  String   @map("client_code") @db.VarChar(20)
  userId      Int?     @map("user_id")
  type        String
  amount      Decimal  @db.Decimal(12,2)
  balance     Decimal  @db.Decimal(12,2)
  description String
  reference   String?
  paymentMode String?  @map("payment_mode")
  paymentId   String?  @map("payment_id")
  status      String   @default("SUCCESS")
  createdAt   DateTime @default(now()) @map("created_at")
  client      Client   @relation(fields: [clientCode], references: [code])

  @@index([clientCode])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Invoice {
  id         Int           @id @default(autoincrement())
  invoiceNo  String        @unique @map("invoice_no")
  clientCode String        @map("client_code") @db.VarChar(20)
  fromDate   String        @map("from_date")
  toDate     String        @map("to_date")
  subtotal   Decimal       @default(0) @db.Decimal(12,2)
  gstPercent    Decimal  @default(18) @db.Decimal(12,4) @map("gst_percent")
  gstAmount  Decimal       @default(0) @map("gst_amount") @db.Decimal(12,2)
  cgstAmount Decimal       @default(0) @map("cgst_amount") @db.Decimal(12,2)
  sgstAmount Decimal       @default(0) @map("sgst_amount") @db.Decimal(12,2)
  igstAmount Decimal       @default(0) @map("igst_amount") @db.Decimal(12,2)
  total      Decimal       @default(0) @db.Decimal(12,2)
  status     String        @default("DRAFT")
  notes      String?
  pdfUrl     String?       @map("pdf_url")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  client     Client        @relation(fields: [clientCode], references: [code])
  items      InvoiceItem[]

  @@index([clientCode])
  @@index([status])
  @@index([fromDate, toDate])
  @@map("invoices")
}

model InvoiceItem {
  id            Int      @id @default(autoincrement())
  invoiceId     Int      @map("invoice_id")
  shipmentId    Int      @map("shipment_id")
  awb           String
  date          String
  consignee     String?
  destination   String?
  courier       String?
  weight        Decimal  @default(0) @db.Decimal(12,4)
  baseAmount    Decimal  @default(0) @map("base_amount") @db.Decimal(12,2)
  fuelSurcharge Decimal  @default(0) @map("fuel_surcharge") @db.Decimal(12,2)
  amount        Decimal  @default(0) @db.Decimal(12,2)
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shipment      Shipment @relation(fields: [shipmentId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  userEmail String?  @map("user_email")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Quote {
  id          Int      @id @default(autoincrement())
  quoteNo     String   @unique @map("quote_no")
  clientCode  String?  @map("client_code") @db.VarChar(20)
  destination String
  pincode     String?
  state       String?
  district    String?
  shipType    String   @map("ship_type")
  weight        Decimal  @db.Decimal(12,4)
  courier     String
  courierMode String   @map("courier_mode")
  costTotal   Decimal  @map("cost_total") @db.Decimal(12,2)
  sellTotal   Decimal  @map("sell_total") @db.Decimal(12,2)
  profit      Decimal  @db.Decimal(12,2)
  margin      Decimal  @db.Decimal(12,2)
  notes       String?
  status      String   @default("QUOTED")
  validUntil  String?  @map("valid_until")
  createdById Int?     @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  client      Client?  @relation(fields: [clientCode], references: [code])
  createdBy   User?    @relation("QuoteCreatedBy", fields: [createdById], references: [id])

  @@index([clientCode])
  @@index([status])
  @@index([createdAt])
  @@map("quotes")
}

model CourierInvoice {
  id           Int                  @id @default(autoincrement())
  courier      String
  invoiceNo    String               @map("invoice_no")
  invoiceDate  String               @map("invoice_date")
  fromDate     String               @map("from_date")
  toDate       String               @map("to_date")
  totalAmount   Decimal  @default(0) @db.Decimal(12,4) @map("total_amount")
  status       String               @default("PENDING")
  notes        String?
  uploadedById Int?                 @map("uploaded_by_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  uploadedBy   User?                @relation("InvoiceUploadedBy", fields: [uploadedById], references: [id])
  items        CourierInvoiceItem[]

  @@index([courier])
  @@index([status])
  @@map("courier_invoices")
}

model CourierInvoiceItem {
  id               Int            @id @default(autoincrement())
  courierInvoiceId Int            @map("courier_invoice_id")
  awb              String
  date             String
  destination      String?
  weight        Decimal  @default(0) @db.Decimal(12,4)
  billedAmount     Decimal        @default(0) @map("billed_amount") @db.Decimal(12,2)
  calculatedAmount Decimal?       @default(0) @map("calculated_amount") @db.Decimal(12,2)
  discrepancy      Decimal?       @default(0) @db.Decimal(12,2)
  status           String         @default("OK")
  notes            String?
  courierInvoice   CourierInvoice @relation(fields: [courierInvoiceId], references: [id], onDelete: Cascade)

  @@index([courierInvoiceId])
  @@index([awb])
  @@map("courier_invoice_items")
}

model MarginRule {
  id           Int      @id @default(autoincrement())
  name         String
  courier      String?
  zone         String?
  shipType     String?  @map("ship_type")
  minMarginPct Decimal  @map("min_margin_pct") @db.Decimal(12,2)
  minProfitAbs Decimal? @map("min_profit_abs") @db.Decimal(12,2)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("margin_rules")
}

model RateVersion {
  id            Int      @id @default(autoincrement())
  courier       String
  effectiveDate String   @map("effective_date")
  uploadedById  Int?     @map("uploaded_by_id")
  notes         String?
  dataJson      Json     @map("data_json")
  createdAt     DateTime @default(now()) @map("created_at")
  uploadedBy    User?    @relation("RateVersionUploadedBy", fields: [uploadedById], references: [id])

  @@index([courier])
  @@map("rate_versions")
}

model Notification {
  id          Int       @id @default(autoincrement())
  clientCode  String?   @map("client_code") @db.VarChar(20)
  awb         String?   @db.VarChar(50)
  channel     String
  to          String
  template    String
  message     String    @db.Text
  status      String    @default("QUEUED")
  provider    String?
  providerRef String?   @map("provider_ref")
  error       String?
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([awb])
  @@index([clientCode])
  @@index([status])
  @@map("notifications")
}

model JobQueue {
  id          Int       @id @default(autoincrement())
  type        String
  payload     Json
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  error       String?
  runAfter    DateTime  @default(now()) @map("run_after")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([status, runAfter])
  @@index([type])
  @@map("job_queue")
}

model DelhiveryPincode {
  id            Int      @id @default(autoincrement())
  pincode       String   @unique
  oda           Boolean  @default(false)
  facilityCity  String?  @map("facility_city")
  facilityState String?  @map("facility_state")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([pincode])
  @@map("delhivery_pincodes")
}

model ScanCorrection {
  id        Int      @id @default(autoincrement())
  field     String
  original  String
  corrected String
  count     Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([field, original])
  @@index([field])
  @@index([count])
  @@map("scan_corrections")
}

model DraftOrder {
  id          Int      @id @default(autoincrement())
  clientCode  String   @map("client_code") @db.VarChar(20)
  referenceId String?  @map("reference_id")
  consignee   String
  destination String
  phone       String?
  pincode     String?
  weight        Decimal  @db.Decimal(12,4)
  status      String   @default("PENDING")
  shipmentId  Int?     @unique @map("shipment_id")
  environment String   @default("production") @db.VarChar(20)
  sandboxRunId String? @map("sandbox_run_id") @db.VarChar(50)
  sourcePlatform String? @map("source_platform") @db.VarChar(30)
  simulationState Json? @map("simulation_state")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client   Client    @relation(fields: [clientCode], references: [code])
  shipment Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([clientCode])
  @@index([status])
  @@index([environment])
  @@index([sandboxRunId])
  @@index([sourcePlatform])
  @@map("draft_orders")
}

model ReturnRequest {
  id              Int       @id @default(autoincrement())
  shipmentId      Int       @map("shipment_id")
  originalAwb     String    @map("original_awb") @db.VarChar(50)
  clientCode      String    @map("client_code") @db.VarChar(20)
  reason          String    // customer_return, damaged, wrong_item, size_exchange, other
  reasonDetail    String?   @map("reason_detail") @db.Text
  status          String    @default("PENDING") // PENDING, APPROVED, LABEL_READY, PICKUP_BOOKED, IN_TRANSIT, RECEIVED, RETURNED_TO_CLIENT, REJECTED
  returnMethod    String    @default("PICKUP") @map("return_method") // PICKUP, SELF_SHIP
  reverseAwb      String?   @map("reverse_awb") @db.VarChar(50)
  reverseCourier  String?   @map("reverse_courier")
  pickupAddress   String?   @map("pickup_address") @db.Text
  pickupCity      String?   @map("pickup_city")
  pickupState     String?   @map("pickup_state")
  pickupPincode   String?   @map("pickup_pincode") @db.VarChar(10)
  pickupPhone     String?   @map("pickup_phone")
  pickupDate      String?   @map("pickup_date") @db.VarChar(10)
  labelUrl        String?   @map("label_url")
  adminNotes      String?   @map("admin_notes") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  shipment        Shipment  @relation(fields: [shipmentId], references: [id])
  client          Client    @relation(fields: [clientCode], references: [code])

  @@index([clientCode])
  @@index([status])
  @@index([returnMethod])
  @@index([originalAwb])
  @@map("return_requests")
}

model AgentMemory {
  id          Int      @id @default(autoincrement())
  category    String   // courier_preference, ndr_pattern, billing_pattern, client_preference, rate_decision
  contextKey  String   @map("context_key")  // e.g. "destination:MUMBAI", "client:ABC", "courier:DTDC"
  decision    String   // The owner's decision/action taken
  metadata    Json?    // Additional context data
  frequency   Int      @default(1)
  lastUsedAt  DateTime @default(now()) @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([category, contextKey, decision])
  @@index([category])
  @@index([frequency])
  @@map("agent_memories")
}

model AgentActionLog {
  id            Int       @id @default(autoincrement())
  actionType    String    @map("action_type")
  params        Json
  result        Json?
  status        String    @default("PENDING")  // PENDING, EXECUTING, DONE, FAILED
  executedBy    String    @default("AGENT") @map("executed_by")  // AGENT or OWNER
  confidence    Float     @default(0)
  ownerApproved Boolean   @default(false) @map("owner_approved")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  @@index([actionType])
  @@index([status])
  @@index([createdAt])
  @@map("agent_action_logs")
}

model ClientWebhook {
  id            Int       @id @default(autoincrement())
  clientCode    String    @map("client_code")
  url           String                          // Client's endpoint URL
  secret        String                          // HMAC-SHA256 signing secret
  events        String[]  @default([])          // ["shipment.booked", "shipment.delivered", ...]
  active        Boolean   @default(true)
  description   String?                         // Human-readable label
  lastDelivery  DateTime? @map("last_delivery") // Last successful delivery timestamp
  failCount     Int       @default(0) @map("fail_count")  // Consecutive failure count
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  client        Client    @relation(fields: [clientCode], references: [code])

  @@index([clientCode])
  @@index([active])
  @@map("client_webhooks")
}

model WebhookDelivery {
  id            Int       @id @default(autoincrement())
  webhookId     Int       @map("webhook_id")
  event         String                          // e.g. "shipment.delivered"
  payload       Json                            // Full signed payload sent
  statusCode    Int?      @map("status_code")   // HTTP response code
  response      String?   @db.Text              // Response body (truncated)
  success       Boolean   @default(false)
  attempts      Int       @default(1)
  maxAttempts   Int       @default(5) @map("max_attempts")
  nextRetryAt   DateTime? @map("next_retry_at")
  error         String?                         // Error message on failure
  deliveredAt   DateTime? @map("delivered_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([webhookId])
  @@index([success])
  @@index([nextRetryAt])
  @@map("webhook_deliveries")
}

// ══════════════════════════════════════════════════════════════
// FEATURE GAP MODELS — Closing gaps vs Shiprocket/Delhivery/DTDC
// ══════════════════════════════════════════════════════════════

// ── Feature 3: COD Remittance Tracking ──────────────────────────────────────
model CODRemittance {
  id              Int       @id @default(autoincrement())
  remittanceNo    String    @unique @map("remittance_no")
  clientCode      String    @map("client_code") @db.VarChar(20)
  courier         String
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(12,2)
  shipmentCount   Int       @default(0) @map("shipment_count")
  status          String    @default("PENDING") // PENDING, COLLECTED, IN_TRANSIT, REMITTED, DISPUTED
  collectedDate   String?   @map("collected_date") @db.VarChar(10)
  expectedRemitDate String? @map("expected_remit_date") @db.VarChar(10)
  actualRemitDate String?   @map("actual_remit_date") @db.VarChar(10)
  utrNumber       String?   @map("utr_number")
  bankReference   String?   @map("bank_reference")
  deductions      Decimal   @default(0) @db.Decimal(12,2)
  netAmount       Decimal   @default(0) @map("net_amount") @db.Decimal(12,2)
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  client          Client    @relation(fields: [clientCode], references: [code])
  shipments       Shipment[]

  @@index([clientCode])
  @@index([status])
  @@index([courier])
  @@map("cod_remittances")
}

// ── Feature 4: Weight Discrepancy Auto-Dispute ──────────────────────────────
model WeightDispute {
  id              Int       @id @default(autoincrement())
  shipmentId      Int       @map("shipment_id")
  awb             String    @db.VarChar(50)
  clientCode      String    @map("client_code") @db.VarChar(20)
  courier         String
  bookedWeight    Decimal   @map("booked_weight") @db.Decimal(12,4)
  billedWeight    Decimal   @map("billed_weight") @db.Decimal(12,4)
  discrepancyPct  Decimal   @map("discrepancy_pct") @db.Decimal(8,2)
  bookedAmount    Decimal   @map("booked_amount") @db.Decimal(12,2)
  billedAmount    Decimal   @map("billed_amount") @db.Decimal(12,2)
  overchargeAmount Decimal  @default(0) @map("overcharge_amount") @db.Decimal(12,2)
  status          String    @default("OPEN") // OPEN, ACCEPTED, DISPUTED, RESOLVED, CLOSED
  autoFlagged     Boolean   @default(true) @map("auto_flagged")
  resolution      String?   // CREDIT_NOTE, ADJUSTED, CARRIER_ACCEPTED, REJECTED
  resolvedAmount  Decimal?  @map("resolved_amount") @db.Decimal(12,2)
  notes           String?   @db.Text
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  shipment        Shipment  @relation(fields: [shipmentId], references: [id])
  client          Client    @relation(fields: [clientCode], references: [code])

  @@index([clientCode])
  @@index([status])
  @@index([courier])
  @@index([awb])
  @@map("weight_disputes")
}

// ── Feature 5: Client Self-Serve Onboarding ─────────────────────────────────
model OnboardingApplication {
  id              Int       @id @default(autoincrement())
  companyName     String    @map("company_name")
  contactName     String    @map("contact_name")
  email           String
  phone           String
  gst             String?
  pan             String?
  address         String?
  city            String?
  state           String?
  pincode         String?   @db.VarChar(10)
  monthlyVolume   String?   @map("monthly_volume") // 1-100, 100-500, 500-2000, 2000+
  businessType    String?   @map("business_type") // ECOMMERCE, B2B, D2C, MARKETPLACE
  primaryCourier  String?   @map("primary_courier")
  website         String?
  status          String    @default("PENDING") // PENDING, UNDER_REVIEW, KYC_REQUIRED, APPROVED, REJECTED
  reviewNotes     String?   @map("review_notes") @db.Text
  approvedById    Int?      @map("approved_by_id")
  clientCode      String?   @map("client_code") @db.VarChar(20) // Set once approved
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  client          Client?   @relation(fields: [clientCode], references: [code])

  @@index([status])
  @@index([email])
  @@map("onboarding_applications")
}

// ── Feature 6: Multi-Warehouse Management ───────────────────────────────────
model Warehouse {
  id              Int       @id @default(autoincrement())
  clientCode      String    @map("client_code") @db.VarChar(20)
  name            String
  code            String    @db.VarChar(20)
  contactName     String    @map("contact_name")
  contactPhone    String    @map("contact_phone")
  contactEmail    String?   @map("contact_email")
  address         String
  city            String
  state           String
  pincode         String    @db.VarChar(10)
  country         String    @default("India")
  isDefault       Boolean   @default(false) @map("is_default")
  active          Boolean   @default(true)
  gstNumber       String?   @map("gst_number")
  operatingHours  String?   @map("operating_hours")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  client          Client    @relation(fields: [clientCode], references: [code])
  shipments       Shipment[]

  @@unique([clientCode, code])
  @@index([clientCode])
  @@index([active])
  @@map("warehouses")
}

// ── Feature 9: Channel Integrations (Shopify/WooCommerce) ───────────────────
model ChannelIntegration {
  id              Int       @id @default(autoincrement())
  clientCode      String    @map("client_code") @db.VarChar(20)
  platform        String    // SHOPIFY, WOOCOMMERCE, CUSTOM
  shopDomain      String?   @map("shop_domain")
  accessToken     String?   @map("access_token")
  apiKey          String?   @map("api_key")
  apiSecret       String?   @map("api_secret")
  webhookSecret   String?   @map("webhook_secret")
  syncEnabled     Boolean   @default(true) @map("sync_enabled")
  autoFulfill     Boolean   @default(false) @map("auto_fulfill")
  defaultCourier  String?   @map("default_courier")
  defaultWarehouse String?  @map("default_warehouse")
  lastSyncAt      DateTime? @map("last_sync_at")
  syncStats       Json?     @map("sync_stats")
  status          String    @default("ACTIVE") // ACTIVE, PAUSED, ERROR, DISCONNECTED
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  client          Client    @relation(fields: [clientCode], references: [code])

  @@unique([clientCode, platform])
  @@index([clientCode])
  @@index([platform])
  @@map("channel_integrations")
}

// ── Feature 10: Customer Feedback/CSAT ──────────────────────────────────────
model CustomerFeedback {
  id              Int       @id @default(autoincrement())
  shipmentId      Int       @map("shipment_id")
  awb             String    @db.VarChar(50)
  clientCode      String    @map("client_code") @db.VarChar(20)
  rating          Int       // 1-5 stars
  comment         String?   @db.Text
  deliveryRating  Int?      @map("delivery_rating") // 1-5
  packagingRating Int?      @map("packaging_rating") // 1-5
  communicationRating Int?  @map("communication_rating") // 1-5
  issues          String[]  @default([]) // LATE_DELIVERY, DAMAGED, WRONG_ITEM, RUDE_AGENT, OTHER
  respondentName  String?   @map("respondent_name")
  respondentPhone String?   @map("respondent_phone")
  token           String    @unique // Unique survey token for public link
  submittedAt     DateTime? @map("submitted_at")
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  shipment        Shipment  @relation(fields: [shipmentId], references: [id])
  client          Client    @relation(fields: [clientCode], references: [code])

  @@index([shipmentId])
  @@index([clientCode])
  @@index([token])
  @@index([rating])
  @@map("customer_feedback")
}

// ── Feature 12: SLA Breach Rules ────────────────────────────────────────────
model SLARule {
  id              Int       @id @default(autoincrement())
  name            String
  courier         String?   // null = applies to all couriers
  service         String?   // null = applies to all services
  maxDays         Int       @map("max_days") // Max days for delivery
  warningDays     Int       @map("warning_days") // Days before breach to warn
  notifyEmail     Boolean   @default(true) @map("notify_email")
  notifyWhatsapp  Boolean   @default(false) @map("notify_whatsapp")
  notifyWebhook   Boolean   @default(false) @map("notify_webhook")
  escalateTo      String?   @map("escalate_to") // Email addresses for escalation
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([active])
  @@index([courier])
  @@map("sla_rules")
}

// ── Feature 13: Razorpay Payment Orders ─────────────────────────────────────
model PaymentOrder {
  id              Int       @id @default(autoincrement())
  clientCode      String    @map("client_code") @db.VarChar(20)
  amount          Decimal   @db.Decimal(12,2)
  currency        String    @default("INR") @db.VarChar(5)
  razorpayOrderId String?   @unique @map("razorpay_order_id")
  razorpayPaymentId String? @map("razorpay_payment_id")
  razorpaySignature String? @map("razorpay_signature")
  status          String    @default("CREATED") // CREATED, PAID, FAILED, REFUNDED
  description     String?
  receipt         String?   @unique
  notes           Json?     @default("{}")
  paidAt          DateTime? @map("paid_at")
  failedAt        DateTime? @map("failed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([clientCode])
  @@index([status])
  @@index([razorpayOrderId])
  @@map("payment_orders")
}
