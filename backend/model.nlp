  "ner": {
    "settings": {
      "tag": "ner",
      "entityPreffix": "%",
      "entitySuffix": "%"
    },
    "rules": {
      "en": {
        "awb": {
          "name": "awb",
          "type": "regex",
          "rules": [
            "/[A-Z0-9]{6,16}/gi"
          ]
        },
        "clientCode": {
          "name": "clientCode",
          "type": "regex",
          "rules": [
            "/\\b[A-Z][A-Z0-9]{2,4}\\b/g"
          ]
        },
        "date": {
          "name": "date",
          "type": "regex",
          "rules": [
            "/\\d{4}-\\d{2}-\\d{2}/gi"
          ]
        },
        "dateRelative": {
          "name": "dateRelative",
          "type": "regex",
          "rules": [
            "/\\b(today|yesterday|tomorrow)\\b/gi"
          ]
        },
        "courier": {
          "name": "courier",
          "type": "regex",
          "rules": [
            "/\\b(dtdc|trackon|delhivery|bluedart|xpressbees)\\b/gi"
          ]
        },
        "weight": {
          "name": "weight",
          "type": "regex",
          "rules": [
            "/\\b\\d+(?:\\.\\d+)?\\s*(?:kg|kgs|kilo|kilograms)\\b/gi"
          ]
        },
        "amount": {
          "name": "amount",
          "type": "regex",
          "rules": [
            "/\\b(?:rs|₹|inr)?\\s*\\d+(?:,\\d{3})*(?:\\.\\d+)?\\b/gi"
          ]
        }
      }
    }
  },
  "nlgManager": {
    "settings": {
      "tag": "nlg-manager"
    },
    "responses": {
      "en": {
        "intent.greetings.hello": [
          {
            "answer": "Hello! I am HawkAI, your enterprise logistics assistant. How can I help you streamline operations today?"
          }
        ],
        "intent.greetings.capabilities": [
          {
            "answer": "I can help you manage your entire logistics pipeline! I can track AWBs, manage clients and wallets, handle returns and NDRs, process invoices, and give you real-time operational reports. Try asking for a **System Overview**."
          }
        ],
        "intent.greetings.thanks": [
          {
            "answer": "You're very welcome! Let me know if you need anything else."
          }
        ],
        "intent.greetings.bye": [
          {
            "answer": "Goodbye! I'll be here monitoring the system when you return."
          }
        ],
        "None": [
          {
            "answer": "I'm not sure what you mean. Try: 'create client', 'track AWB', 'generate invoice', 'daily report', 'show overview', 'wallet balance', or 'list returns'."
          }
        ]
      }
    }
  },
  "actionManager": {
    "settings": {
      "tag": "action-manager"
    },
    "actions": {}
  },
