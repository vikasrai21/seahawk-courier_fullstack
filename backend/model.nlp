  "ner": {
    "settings": {
      "tag": "ner",
      "entityPreffix": "%",
      "entitySuffix": "%"
    },
    "rules": {
      "en": {
        "awb": {
          "name": "awb",
          "type": "regex",
          "rules": [
            "/[A-Z0-9]{6,16}/gi"
          ]
        },
        "clientCode": {
          "name": "clientCode",
          "type": "regex",
          "rules": [
            "/\\b[A-Z][A-Z0-9]{2,4}\\b/g"
          ]
        },
        "date": {
          "name": "date",
          "type": "regex",
          "rules": [
            "/\\d{4}-\\d{2}-\\d{2}/gi"
          ]
        },
        "dateRelative": {
          "name": "dateRelative",
          "type": "regex",
          "rules": [
            "/\\b(today|yesterday|tomorrow)\\b/gi"
          ]
        },
        "courier": {
          "name": "courier",
          "type": "regex",
          "rules": [
            "/\\b(dtdc|trackon|delhivery|bluedart|xpressbees)\\b/gi"
          ]
        },
        "weight": {
          "name": "weight",
          "type": "regex",
          "rules": [
            "/\\b\\d+(?:\\.\\d+)?\\s*(?:kg|kgs|kilo|kilograms)\\b/gi"
          ]
        },
        "amount": {
          "name": "amount",
          "type": "regex",
          "rules": [
            "/\\b(?:rs|₹|inr)?\\s*\\d+(?:,\\d{3})*(?:\\.\\d+)?\\b/gi"
          ]
        }
      }
    }
  },
  "nlgManager": {
    "settings": {
      "tag": "nlg-manager"
    },
    "responses": {
      "en": {
        "None": [
          {
            "answer": "I'm not sure what you mean. Try: 'create client', 'track AWB', 'generate invoice', 'daily report', 'show overview', 'wallet balance', or 'list returns'."
          }
        ]
      }
    }
  },
