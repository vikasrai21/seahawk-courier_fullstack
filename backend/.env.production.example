# ═══════════════════════════════════════════════
#  SEAHAWK v2 — PRODUCTION CONFIG
#  Rename to .env.production on your server
# ═══════════════════════════════════════════════

NODE_ENV=production
PORT=3001

DATABASE_URL="postgresql://seahawk_user:STRONG_PASSWORD@localhost:5432/seahawk_v6"

# CRITICAL: Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING"

JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=30d

# Your actual domain(s)
CORS_ORIGIN=https://yourdomain.com

LOGIN_RATE_MAX=5
GLOBAL_RATE_MAX=200
