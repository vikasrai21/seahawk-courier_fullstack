# ═══════════════════════════════════════════════
#  SEAHAWK v2 — PRODUCTION CONFIG
#  Rename to .env.production on your server
# ═══════════════════════════════════════════════

NODE_ENV=production
PORT=3001

DATABASE_URL="postgresql://seahawk_user:STRONG_PASSWORD@localhost:5432/seahawk_v6"

# CRITICAL: Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING"

JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=30d

# Your actual domain(s)
CORS_ORIGIN=https://yourdomain.com

# OCR engine (free local by default)
OCR_ENGINE=local
OCR_PYTHON_BIN=python
OCR_LOCAL_TIMEOUT_MS=60000
SCANNER_SLA_BARCODE_FIRST_PASS_PCT=92
SCANNER_SLA_AWB_EXTRACTION_PCT=97
SCANNER_SLA_OCR_FALLBACK_MAX_PCT=15
SCANNER_SLA_FALSE_LOCK_MAX_PCT=1
SCANNER_SLA_LOCK_P95_MS=800
SCANNER_SLA_FAST_P95_MS=1200
SCANNER_SLA_OCR_P95_MS=20000
SCANNER_OCR_BUDGET_MS=22000
SCANNER_DATASET_BUCKET=
SCANNER_DATASET_PREFIX=scanner-gold
# Optional paid fallback:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

LOGIN_RATE_MAX=5
GLOBAL_RATE_MAX=200
