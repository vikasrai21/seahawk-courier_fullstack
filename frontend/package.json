{
  "name": "seahawk-frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy:scanbot": "node scripts/copy-scanbot-wasm.mjs",
    "dev": "npm run copy:scanbot && vite",
    "build": "npm run copy:scanbot && vite build",
    "build:ci": "npm run copy:scanbot && vite build && node scripts/check-bundle-budget.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "preview": "vite preview",
    "lint": "eslint src --ext .jsx,.js",
    "lint:strict": "eslint src --ext .jsx,.js --max-warnings 0",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@zxing/browser": "^0.1.5",
    "axios": "^1.15.1",
    "brace-expansion": "^1.1.13",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.363.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "scanbot-web-sdk": "^8.1.1",
    "seahawk-fullstack": "file:..",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12",
    "zxing-wasm": "^3.0.2"
  },
  "overrides": {
    "follow-redirects": "^1.16.0",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
