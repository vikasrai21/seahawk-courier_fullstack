{
  "expo": {
    "name": "Seahawk Mobile",
    "slug": "seahawk-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.seahawk.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0f1a"
      },
      "package": "com.seahawk.mobile"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
